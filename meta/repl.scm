  (environment-variable-set! 'call-with-values call-with-values)
  (environment-variable-set! 'dynamic-wind dynamic-wind)

  #t)

(define repl:prelude
  '((define (for-each func lst)
      (cond ((null? lst) #f)
            (else (func (car lst))
                  (for-each func (cdr lst)))))

    (define (map proc items)
      (if (null? items)
          '()
          (cons (proc (car items))
                (map proc (cdr items)))))))

(define (repl:eval-prelude)
  (let loop ((exprs repl:prelude))
    (if (null? exprs)
        #t
        (let* ((expanded (macroexpand (car exprs)))
               (optimized (optimize expanded))
               (code (compile optimized))
               (bytecode (generate-bytecode code))
               (ctx (vm:init-context bytecode)))
          (vm:vm-run ctx)
          (loop (cdr exprs))))))

(define (run-repl)
  (display "Starting REPL...\n")
  (repl:init-globals)
  (repl:eval-prelude)
  
  (let loop ()
    (display "> ")
    (flush-output-port (current-output-port))
    (let ((expr (read)))
      (if (eof-object? expr)
          (newline)
          (with-exception-handler
           (lambda (e)
             (display "error: ")
             (display (if (condition? e) (condition-message e) e))
             (newline)
             (loop))
           (lambda ()
             (let* ((expanded (macroexpand expr))
                    (optimized (optimize expanded))
                    (lifted (lambda-lift optimized))
                    (code (compile lifted))
                    (bytecode (generate-bytecode code))
                    (ctx (vm:init-context bytecode)))
               (newline)
               (display "macroexpanded form:\n")
               (write expanded)
               (newline)
               (newline)
               (display "optimized form:\n")
               (write optimized)
               (newline)
               (newline)
               (display "lifted form:\n")
               (write lifted)
               (newline)
               (newline)
               (display "compiled code for nanos input:\n")
               (write code)
               (newline)
               (newline)
               (let ((result (vm:vm-run ctx)))
                 (write result)
                 (newline)
                 (loop)))))))))
