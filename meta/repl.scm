;;; REPL for Research Scheme
;;; Integrates macroexpand, optimizer, compiler, and VM.

;; Add load paths relative to this script to find dependencies in core/ and meta/.
;; For best results, run from the project root.
(cond-expand
  (gauche
   (add-load-path "." :relative)
   (add-load-path "../core" :relative)
   (define (flush-output-port port) (flush))
   (define (with-exception-handler handler thunk)
     (guard (e (else (handler e)))
       (thunk))))
  (ypsilon
   (add-load-path "./core")
   (add-load-path "./meta"))
  (else))

;; Load dependencies
(load "core.scm")  ; Load core system
(load "vm.scm")            ; Load VM (meta-specific)

