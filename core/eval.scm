(define (core-eval expr env)
  (let* ((expanded (macroexpand expr))
         (optimized (optimize expanded))
         (lifted (lambda-lift optimized))
         (coreform (compile lifted)))
    (newline)
    (display "macroexpanded form:\n")
    (write expanded)
    (newline)
    (newline)
    (display "optimized form:\n")
    (write optimized)
    (newline)
    (newline)
    (display "lifted form:\n")
    (write lifted)
    (newline)
    (newline)
    (display "compiled code for nanos input:\n")
    (write coreform)
    (newline)
    (newline)
    (codegen-and-run coreform)))